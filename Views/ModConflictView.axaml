<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:l4d2_mod_manager.ViewModels"
             x:Class="l4d2_mod_manager.Views.ModConflictView"
             x:DataType="vm:MainWindowViewModel">
    
    <StackPanel>
        <TextBlock Text="Conflicts Found:"/>
        <ListBox ItemsSource="{Binding ConflictList}"/>        
    </StackPanel>
</UserControl>
